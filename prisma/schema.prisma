generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Job {
  id            String      @id @default(cuid())
  titleAr       String
  titleEn       String?
  descriptionAr String      @db.Text
  category      String?
  level         String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  skills        JobSkill[]
  paths         LearningPath[]
}

model Skill {
  id        String      @id @default(cuid())
  nameAr    String      @unique
  nameEn    String?
  category  String?
  createdAt DateTime    @default(now())
  jobs      JobSkill[]
  courses   CourseSkill[]
}

model JobSkill {
  id         String  @id @default(cuid())
  jobId      String
  skillId    String
  importance Int     @default(3) // 1..5
  job        Job     @relation(fields: [jobId], references: [id], onDelete: Cascade)
  skill      Skill   @relation(fields: [skillId], references: [id], onDelete: Cascade)

  @@unique([jobId, skillId])
}

model Company {
  id          String   @id @default(cuid())
  nameAr      String
  nameEn      String?
  industry    String?
  website     String?
  logoUrl     String?
  description String?  @db.Text
  createdAt   DateTime @default(now())
}

model Platform {
  id      String   @id @default(cuid())
  nameAr  String
  nameEn  String?
  website String?
  logoUrl String?
  courses Course[]
}

model Course {
  id           String        @id @default(cuid())
  titleAr      String
  titleEn      String?
  description  String?       @db.Text
  url          String?
  durationHrs  Int?
  level        String?
  isFree       Boolean       @default(false)
  language     String?       @default("ar")
  platformId   String?
  platform     Platform?     @relation(fields: [platformId], references: [id], onDelete: SetNull)
  skills       CourseSkill[]
  paths        LearningPathCourse[]
  createdAt    DateTime      @default(now())
}

model CourseSkill {
  id       String @id @default(cuid())
  courseId String
  skillId  String
  course   Course @relation(fields: [courseId], references: [id], onDelete: Cascade)
  skill    Skill  @relation(fields: [skillId], references: [id], onDelete: Cascade)

  @@unique([courseId, skillId])
}

model LearningPath {
  id          String                 @id @default(cuid())
  titleAr     String
  description String?                @db.Text
  jobId       String?
  job         Job?                   @relation(fields: [jobId], references: [id], onDelete: SetNull)
  courses     LearningPathCourse[]
  createdAt   DateTime               @default(now())
}

model LearningPathCourse {
  id     String       @id @default(cuid())
  pathId String
  courseId String
  order  Int          @default(0)
  path   LearningPath @relation(fields: [pathId], references: [id], onDelete: Cascade)
  course Course       @relation(fields: [courseId], references: [id], onDelete: Cascade)
}

model Report {
  id              String   @id @default(cuid())
  fullName        String
  jobTitle        String
  employer        String?
  currentSkills   String   @db.Text
  currentCourses  String?  @db.Text
  matchedJobId    String?
  data            Json
  createdAt       DateTime @default(now())
}
