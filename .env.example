# ─── Database (Prisma / MySQL-MariaDB) ───────────────────────────────
DATABASE_URL="mysql://user:password@127.0.0.1:3306/dbname"

# ─── Admin auth ──────────────────────────────────────────────────────
# JWT signing secret — must be at least 16 chars (32+ recommended).
AUTH_SECRET="change-this-to-a-long-random-string-32chars-min"
ADMIN_EMAIL="info@masaary.com"
ADMIN_PASSWORD="change-this"

# ─── Claude AI ───────────────────────────────────────────────────────
# Read DB-first from the Setting table (set it in the admin settings page),
# with this env var as the fallback.
ANTHROPIC_API_KEY="sk-ant-..."

# ─── Email (SMTP) — optional; mailer self-disables if HOST/USER/PASSWORD missing
SMTP_HOST="smtp.hostinger.com"
SMTP_PORT="465"
SMTP_SECURE="true"
SMTP_USER="info@masaary.com"
SMTP_PASSWORD="change-this"
SMTP_FROM="info@masaary.com"
NOTIFY_EMAIL="info@masaary.com"

# ─── Site URLs ───────────────────────────────────────────────────────
SITE_URL="https://masaary.com"
# NOTE: every NEXT_PUBLIC_* below is inlined at BUILD time — set before `next build`.
NEXT_PUBLIC_SITE_URL="https://masaary.com"
NEXT_PUBLIC_SITE_HOST="masaary.com"

# ─── Payment details shown on /pay/[id] (build-time) ─────────────────
NEXT_PUBLIC_PAY_BANK="مصرف الراجحي"
NEXT_PUBLIC_PAY_BENEFICIARY="منصة مساري"
NEXT_PUBLIC_PAY_IBAN="SA00 0000 0000 0000 0000 0000"
NEXT_PUBLIC_PAY_AMOUNT="٥٠ ريال"
NEXT_PUBLIC_PAY_WHATSAPP="966500000000"
NEXT_PUBLIC_PAY_EMAIL="info@masaary.com"
