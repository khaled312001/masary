# Backend API URL (server-side fetch)
API_URL="http://localhost:4000"
# Same URL exposed to client (must be same as API_URL or its public version)
NEXT_PUBLIC_API_URL="http://localhost:4000"

# JWT secret — MUST match the backend's AUTH_SECRET
AUTH_SECRET="masary-super-secret-change-this-in-production-32chars-min"
